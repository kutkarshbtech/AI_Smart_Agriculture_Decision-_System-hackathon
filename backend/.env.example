# SwadeshAI Backend Environment Variables
# Copy this file to .env and fill in your values

# App
APP_ENV=development
DEBUG=true

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3
S3_BUCKET_NAME=swadesh-ai-data-ap

# Amazon Bedrock (LLM)
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_REGION=us-east-1

# Amazon Transcribe (Speech-to-Text)
TRANSCRIBE_REGION=ap-south-1

# Amazon Polly (Text-to-Speech)
POLLY_REGION=us-east-1

# External APIs
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5
MANDI_API_BASE_URL=https://api.data.gov.in/resource
MANDI_API_KEY=your-data-gov-in-api-key

# Database (for production — demo uses in-memory)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/swadesh_ai

# Neptune
NEPTUNE_ENDPOINT=
NEPTUNE_PORT=8182

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production
